{
  "name": "discourse-releases",
  "version": "0.0.0",
  "private": true,
  "description": "Discourse release history, changelogs, and version support information",
  "repository": "",
  "license": "MIT",
  "author": "",
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "scripts": {
    "build": "vite build && BUILD_SSR=true vite build && node ./scripts/prerender.mjs && node ./scripts/generate-rss.mjs",
    "build:data": "concurrently 'node lib/write-commit-info.mjs' 'node lib/fetch-new-features.mjs' 'node lib/fetch-security-advisories.mjs'",
    "build:data:advisories": "node lib/fetch-security-advisories.mjs",
    "build:full": "pnpm build:data && pnpm build",
    "format": "prettier . --cache --write",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\" --prefixColors auto",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:css:fix": "concurrently \"pnpm:lint:css --fix\"",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\" --prefixColors auto && pnpm format",
    "lint:format": "prettier . --cache --check",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "start": "vite",
    "test": "vite build --mode development && ember test --path dist"
  },
  "exports": {
    "./tests/*": "./tests/*",
    "./*": "./app/*"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/runtime": "^7.29.2",
    "@ember/optional-features": "^3.0.0",
    "@ember/string": "^4.0.1",
    "@ember/test-helpers": "^5.4.1",
    "@ember/test-waiters": "^4.1.1",
    "@embroider/compat": "^4.1.17",
    "@embroider/config-meta-loader": "^1.0.0",
    "@embroider/core": "^4.4.7",
    "@embroider/legacy-inspector-support": "^0.1.3",
    "@embroider/macros": "^1.20.2",
    "@embroider/router": "^3.0.6",
    "@embroider/vite": "^1.7.2",
    "@eslint/js": "^9.39.2",
    "@glimmer/component": "^2.1.1",
    "@rollup/plugin-babel": "^7.0.0",
    "babel-plugin-ember-template-compilation": "^4.0.0",
    "concurrently": "^9.2.1",
    "decorator-transforms": "^2.3.1",
    "ember-auto-import": "^2.13.1",
    "ember-cli": "~6.11.2",
    "ember-cli-babel": "^8.3.1",
    "ember-load-initializers": "^3.0.1",
    "ember-modifier": "^4.3.0",
    "ember-page-title": "^9.0.3",
    "ember-qunit": "^9.0.4",
    "ember-resolver": "^13.2.0",
    "ember-source": "~6.12.0",
    "ember-template-lint": "^7.9.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ember": "^12.7.5",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-qunit": "^8.2.6",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-ember-template-tag": "^2.1.3",
    "qunit": "^2.25.0",
    "qunit-dom": "^3.5.0",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "testem": "^3.20.0",
    "tracked-built-ins": "^4.1.2",
    "vite": "8.0.7"
  },
  "engines": {
    "node": ">= 20"
  },
  "ember": {
    "edition": "octane"
  },
  "dependencies": {
    "@discourse/lint-configs": "^2.44.1",
    "@eslint/compat": "^2.0.4",
    "@glint/ember-tsc": "^1.5.0",
    "@html-next/vertical-collection": "^5.0.3",
    "execa": "^9.6.1",
    "fast-xml-parser": "^5.5.10",
    "jsdom": "^29.0.2",
    "lucide": "^1.7.0",
    "semver": "^7.7.4"
  }
}
